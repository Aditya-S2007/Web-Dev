<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h3>All chats!</h3>
    <form method="get" action="/chats/new">
        <button>New chat</button>
    </form>
    <br>
    <% for(let chat of chats){ %>
    <div class="chat">
        <p>from:<i> <%= chat.from %></p></i>
        <div class="msg">
            <p><%= chat.msg %></p>
            <form method="get" action="/chats/<%= chat._id %>/edit"> <!--loop m h..-->
                <button>edit</button>
            </form>
            <br>
             <form method="post" action="/chats/<%= chat._id %>?_method=DELETE"> <!--loop m h..-->
                <button>delete</button>
            </form>
        </div>
            <p>Recieved by<i> <%= chat.to %></p></i>
            <hr>
        <p><%= chat.create_at.toString().split(" ")[4] %></p>    <!-- convert into sting ,split with white space,store in array [4] is index of array  -->
        <p><%= chat.create_at.toString().split(" ").slice(0,4).join("-") %></p>
    </div>
    <br><br>
    <% } %>
    
</body>
</html>